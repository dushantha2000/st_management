<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_student_form" model="ir.ui.view">
        <field name="name">student.student.form</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">


            <!--user data input-->
            <form string="Student">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="registration_id" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>


                            <!--NIC number -->
                            <field name="nic_number"/>


                            <field name="name"/>
                            <field name="course_ids" widget="many2many_tags"/>
                            <field name="address"/>
                            <field name="phone_number"/>
                            <field name="nationality"/>
                            <field name="age"/>
                            <field name="gender"/>


                            <!--test field-->
                            <!--<field name="test_age"/>-->


                        </group>
                        <group>
                            <field name="dob"/>

                        </group>
                    </group>
                    <notebook>
                        <page string="Enrolled Courses" name="courses">
                            <field name="course_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="standard_price" string="Course Fee"/>
                                </list>
                            </field>
                        </page>
                        <page string="Fees History" name="fees">
                            <field name="fee_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="course_id"/>
                                    <field name="date"/>
                                    <field name="amount_paid"/>
                                    <field name="state" widget="badge" decoration-success="state == 'paid'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>


                <!--log note handling-->
                <chatter/>


            </form>
        </field>
    </record>


    <!-- student  views    -->
    <record id="view_student_list" model="ir.ui.view">
        <field name="name">student.student.list</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            <list string="Students">
                <field name="registration_id"/>



                <!--NIC number col-->
                <field name="nic_number"/>



                <field name="name"/>
                <field name="address"/>
                <field name="age"/>
                <field name="nationality"/>
                <field name="phone_number"/>


                <!-- courses -->
                <field name="course_ids"
                       widget="many2many_tags"
                />


                <!--Add to the badges-->
                <field name="gender"
                       widget="badge"
                       decoration-info="gender == 'male'"
                       decoration-danger="gender == 'female'"
                       decoration-success="gender == 'other'"
                />

            </list>
        </field>
    </record>

    <record id="action_student_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">student.student</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first student!
            </p>
        </field>
    </record>

</odoo>