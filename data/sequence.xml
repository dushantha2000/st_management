<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--  Student Index Number -->
        <record id="seq_student_index" model="ir.sequence">
            <field name="name">Student Index Sequence</field>
            <field name="code">student.student</field>
            <field name="prefix">STU-</field>
            <field name="padding">3</field>
            <field name="company_id" eval="False"/>
        </record>

        <!--  Student Fees -->
        <record id="seq_student_fees" model="ir.sequence">
            <field name="name">Student Fees Sequence</field>
            <field name="code">student.fees</field>
            <field name="prefix">FEE-</field>
            <field name="padding">3</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
